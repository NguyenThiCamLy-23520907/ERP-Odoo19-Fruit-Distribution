<odoo>
    <record id="view_fruit_wastage_log_form" model="ir.ui.view">
        <field name="name">fruit.wastage.log.form</field>
        <field name="model">fruit.wastage.log</field>
        <field name="arch" type="xml">
            <form string="Fruit Wastage Log">
                <header>
                    <button name="action_post"
                            type="object"
                            string="Post"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="date"/>
                            <field name="qc_check_id"/>
                            <field name="picking_id"/>
                        </group>
                        <group>
                            <field name="product_id"/>
                            <field name="lot_id"/>
                            <field name="qty"/>
                            <field name="uom_id"/>
                            <field name="unit_cost"/>
                            <field name="amount"/>
                            <field name="reason_type"/>
                        </group>
                    </group>
                    <field name="note"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_fruit_wastage_log_tree" model="ir.ui.view">
        <field name="name">fruit.wastage.log.tree</field>
        <field name="model">fruit.wastage.log</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="product_id"/>
                <field name="lot_id"/>
                <field name="qty"/>
                <field name="amount"/>
                <field name="reason_type"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="action_fruit_wastage_log" model="ir.actions.act_window">
        <field name="name">Wastage Logs</field>
        <field name="res_model">fruit.wastage.log</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_fruit_wastage_log"
              name="Wastage Logs"
              parent="menu_fruit_operations_root"
              action="action_fruit_wastage_log"
              sequence="20"/>
</odoo>