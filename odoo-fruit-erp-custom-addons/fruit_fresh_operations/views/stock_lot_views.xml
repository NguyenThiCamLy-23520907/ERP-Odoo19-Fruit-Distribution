<odoo>
    <record id="view_stock_lot_form_fruit_custom" model="ir.ui.view">
        <field name="name">stock.lot.form.fruit.custom</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/group" position="inside">
                <group string="Fruit Fresh Information">
                    <field name="x_harvest_date"/>
                    <field name="x_expiry_date"/>
                    <field name="x_grade"/>
                    <field name="x_qc_status"/>
                    <field name="x_source_farm"/>
                    <field name="x_days_to_expiry" readonly="1"/>
                    <field name="x_fefo_alert" readonly="1"/>
                    <field name="x_qc_note"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="view_stock_lot_tree_fruit_custom" model="ir.ui.view">
        <field name="name">stock.lot.tree.fruit.custom</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="x_expiry_date"/>
                <field name="x_days_to_expiry"/>
                <field name="x_fefo_alert" widget="badge" 
                       decoration-danger="x_fefo_alert == 'red' or x_fefo_alert == 'expired'" 
                       decoration-warning="x_fefo_alert == 'yellow'" 
                       decoration-success="x_fefo_alert == 'green'"/>
                <field name="x_qc_status" widget="badge"
                       decoration-success="x_qc_status == 'passed'"
                       decoration-danger="x_qc_status == 'failed'"
                       decoration-warning="x_qc_status == 'partial'"/>
            </xpath>
        </field>
    </record>

    <record id="action_fefo_batch_control" model="ir.actions.act_window">
        <field name="name">FEFO Batch Control</field>
        <field name="res_model">stock.lot</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('x_fefo_alert', 'in', ['red', 'yellow'])]</field>
    </record>

    <menuitem id="menu_fefo_batch_control"
              name="FEFO Batch Control"
              parent="menu_fruit_operations_root"
              action="action_fefo_batch_control"
              sequence="30"/>
</odoo>
